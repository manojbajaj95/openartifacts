# Public URL of this app (used in share links)
OA_VIEWER_URL=http://localhost:3000

# PostgreSQL (local docker-compose default shown)
DATABASE_URL=postgres://openartifacts:openartifacts@localhost:5432/openartifacts

# S3-compatible storage (Supabase, MinIO, AWS, etc.)
OA_S3_ENDPOINT=https://YOUR_PROJECT.supabase.co/storage/v1/s3
OA_S3_REGION=us-east-1
OA_S3_BUCKET=artifacts
OA_S3_ACCESS_KEY=your-access-key
OA_S3_SECRET_KEY=your-secret-key

# Optional: CLI defaults (when running oa against this instance)
# OA_SERVER_URL=http://localhost:3000
# OA_VIEWER_URL=http://localhost:3000
