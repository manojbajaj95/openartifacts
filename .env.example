# Public URL of this app (used in share links)
OA_VIEWER_URL=https://openartifacts.dev

# Supabase Postgres — use DIRECT connection (port 5432) for local migrations
DATABASE_URL=postgres://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# On Vercel, use the TRANSACTION POOLER (port 6543) instead:
# DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Storage (S3-compatible)
OA_S3_ENDPOINT=https://[project-ref].supabase.co/storage/v1/s3
OA_S3_REGION=us-east-1
OA_S3_BUCKET=artifacts
OA_S3_ACCESS_KEY=your-s3-access-key
OA_S3_SECRET_KEY=your-s3-secret-key
